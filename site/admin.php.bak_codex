<div class="main-layout" style="max-width: 1200px;">
    <div class="content-area" style="width: 100%;">
        <div class="card">
            <div class="card-header">
                <div class="card-title">Список техніки в грі (Всього: <?php echo $total_items; ?>)</div>
            </div>
            <div class="card-body">
                <form action="admin.php" method="GET" class="tanks-filters">
                    <input type="text" name="search" class="form-control search-input" placeholder="Пошук танка за назвою..." value="<?php echo htmlspecialchars($search); ?>">
                    
                    <select name="nation" class="form-control" style="width: 150px;">
                        <option value="">Всі нації</option>
                        <option value="ussr" <?php echo $filter_nation === 'ussr' ? 'selected' : ''; ?>>СРСР</option>
                        <option value="germany" <?php echo $filter_nation === 'germany' ? 'selected' : ''; ?>>Німеччина</option>
                        <option value="usa" <?php echo $filter_nation === 'usa' ? 'selected' : ''; ?>>США</option>
                        <option value="france" <?php echo $filter_nation === 'france' ? 'selected' : ''; ?>>Франція</option>
                        <option value="china" <?php echo $filter_nation === 'china' ? 'selected' : ''; ?>>Китай</option>
                    </select>

                    <select name="class" class="form-control" style="width: 150px;">
                        <option value="">Всі класи</option>
                        <option value="lightTank" <?php echo $filter_class === 'lightTank' ? 'selected' : ''; ?>>Легкі танки</option>
                        <option value="mediumTank" <?php echo $filter_class === 'mediumTank' ? 'selected' : ''; ?>>Середні танки</option>
                        <option value="heavyTank" <?php echo $filter_class === 'heavyTank' ? 'selected' : ''; ?>>Важкі танки</option>
                        <option value="AT-SPG" <?php echo $filter_class === 'AT-SPG' ? 'selected' : ''; ?>>ПТ-САУ</option>
                        <option value="SPG" <?php echo $filter_class === 'SPG' ? 'selected' : ''; ?>>САУ (Арта)</option>
                    </select>

                    <select name="tier" class="form-control" style="width: 100px;">
                        <option value="">Всі рівні</option>
                        <?php for ($i = 1; $i <= 10; $i++): ?>
                            <option value="<?php echo $i; ?>" <?php echo $filter_tier === strval($i) ? 'selected' : ''; ?>>Рівень <?php echo $i; ?></option>
                        <?php endfor; ?>
                    </select>

                    <select name="status" class="form-control" style="width: 150px;">
                        <option value="">Всі статуси</option>
                        <option value="enabled" <?php echo $filter_status === 'enabled' ? 'selected' : ''; ?>>Доступні</option>
                        <option value="disabled" <?php echo $filter_status === 'disabled' ? 'selected' : ''; ?>>Відключені</option>
                    </select>

                    <button type="submit" class="btn btn-primary">Фільтрувати</button>
                    <a href="admin.php" class="btn btn-secondary">Скинути</a>
                </form>

                <div class="tanks-table-container">
                    <table class="tanks-table">
                        <thead>
                            <tr>
                                <th>Назва</th>
                                <th>Нація</th>
                                <th>Клас</th>
                                <th>Рівень</th>
                                <th>Статус</th>
                                <th>Доступність у грі</th>
                            </tr>
                        </thead>
                        <tbody>
                            <?php foreach ($paginated_vehicles as $v): ?>
                                <?php 
                                $name = $v['name'] ?? '';
                                $nation = $v['nation'] ?? 'ussr';
                                $class = $v['vehicleClass'] ?? 'mediumTank';
                                $level = $v['level_calculated'] ?? 1;
                                $is_enabled = $v['is_enabled'];
                                $unique_id = btoa_safe($name);
                                ?>
                                <tr>
                                    <td style="font-weight: 600; color: #ffffff;"><?php echo htmlspecialchars($name); ?></td>
                                    <td><span class="badge badge-<?php echo $nation; ?>"><?php echo htmlspecialchars($nation); ?></span></td>
                                    <td><?php echo htmlspecialchars($class); ?></td>
                                    <td style="font-weight: 600; color: #e5a93b;"><?php echo $level; ?></td>
                                    <td id="status-<?php echo $unique_id; ?>">
                                        <?php if ($is_enabled): ?>
                                            <span class="status-active">Доступний</span>
                                        <?php else: ?>
                                            <span class="status-disabled">Відключений</span>
                                        <?php endif; ?>
                                    </td>
                                    <td>
                                        <label class="switch">
                                            <input type="checkbox" <?php echo $is_enabled ? 'checked' : ''; ?> onchange="toggleTank(this, '<?php echo htmlspecialchars($name, ENT_QUOTES); ?>')">
                                            <span class="slider"></span>
                                        </label>
                                    </td>
                                </tr>
                            <?php endforeach; ?>
                            <?php if (empty($paginated_vehicles)): ?>
                                <tr>
                                    <td colspan="6" style="text-align: center; padding: 30px; color: #8c8c8c;">Танків не знайдено.</td>
                                </tr>
                            <?php endif; ?>
                        </tbody>
                    </table>
                </div>

                <?php if ($total_pages > 1): ?>
                    <div class="pagination">
                        <?php 
                        $query_params = $_GET;
                        for ($i = 1; $i <= $total_pages; $i++): 
                            $query_params['page'] = $i;
                            $link = 'admin.php?' . http_build_query($query_params);
                        ?>
                            <a href="<?php echo htmlspecialchars($link); ?>" class="pagination-item <?php echo $page === $i ? 'active' : ''; ?>"><?php echo $i; ?></a>
                        <?php endfor; ?>
                    </div>
                <?php endif; ?>
            </div>
        </div>
    </div>
</div>

<div class="footer">

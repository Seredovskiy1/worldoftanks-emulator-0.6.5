<?php
require_once 'db.php';

if (!isset($_SESSION['user_id']) || !isset($_SESSION['is_admin']) || !$_SESSION['is_admin']) {
    header('Location: login.php?error=admin');
    exit;
}

if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_GET['ajax'])) {
    header('Content-Type: application/json');
    $tank_name = trim($_POST['tank_name'] ?? '');
    $status = intval($_POST['status'] ?? 0);

    if (empty($tank_name)) {
        echo json_encode(['success' => false, 'error' => 'Invalid parameters']);
        exit;
    }

    try {
        if ($status === 1) {
            $stmt = $pdo->prepare("DELETE FROM disabled_vehicles WHERE vehicle_name = ?");
            $stmt->execute([$tank_name]);
        } else {
            $stmt = $pdo->prepare("INSERT INTO disabled_vehicles (vehicle_name) VALUES (?) ON DUPLICATE KEY UPDATE vehicle_name = vehicle_name");
            $stmt->execute([$tank_name]);
        }
        echo json_encode(['success' => true]);
    } catch (Exception $e) {
        echo json_encode(['success' => false, 'error' => $e->getMessage()]);
    }
    exit;
}

$disabled_tanks = [];
try {
    $stmt = $pdo->query("SELECT vehicle_name FROM disabled_vehicles");
    $disabled_tanks = $stmt->fetchAll(PDO::FETCH_COLUMN);
} catch (Exception $e) {
}

$disabled_set = array_flip($disabled_tanks);

$json_path = '_vehicles.json';
$vehicles = [];
if (file_exists($json_path)) {
    $json_content = file_get_contents($json_path);
    $data = json_decode($json_content, true);
    if (isset($data['vehicles'])) {
        $vehicles = $data['vehicles'];
    }
}

$search = trim($_GET['search'] ?? '');
$filter_nation = $_GET['nation'] ?? '';
$filter_class = $_GET['class'] ?? '';
$filter_tier = $_GET['tier'] ?? '';
$filter_status = $_GET['status'] ?? '';

$filtered_vehicles = [];
foreach ($vehicles as $v) {
    $name = $v['name'] ?? '';
    $nation = $v['nation'] ?? '';
    $class = $v['vehicleClass'] ?? '';
    
    $level = 1;
    if (isset($v['tags'])) {
        foreach ($v['tags'] as $tag) {
            if (preg_match('/^tier(\d+)$/i', $tag, $matches)) {
                $level = intval($matches[1]);
                break;
            }
        }
    }
    
    $is_enabled = !isset($disabled_set[$name]);

    if (!empty($search) && stripos($name, $search) === false) {
        continue;
    }
    if (!empty($filter_nation) && $nation !== $filter_nation) {
        continue;
    }
    if (!empty($filter_class) && $class !== $filter_class) {
        continue;
    }
    if (!empty($filter_tier) && $level !== intval($filter_tier)) {
        continue;
    }
    if ($filter_status !== '') {
        if ($filter_status === 'enabled' && !$is_enabled) {
            continue;
        }
        if ($filter_status === 'disabled' && $is_enabled) {
            continue;
        }
    }

    $v['level_calculated'] = $level;
    $v['is_enabled'] = $is_enabled;
    $filtered_vehicles[] = $v;
}

$page = max(1, intval($_GET['page'] ?? 1));
$limit = 25;
$total_items = count($filtered_vehicles);
$total_pages = ceil($total_items / $limit);
$offset = ($page - 1) * $limit;
$paginated_vehicles = array_slice($filtered_vehicles, $offset, $limit);
?>
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>World of Tanks 0.6.5 - Управління танками</title>
    <link rel="stylesheet" href="style.css">
    <script>
        function toggleTank(checkbox, tankName) {
            const isEnabled = checkbox.checked ? 1 : 0;
            const formData = new FormData();
            formData.append('tank_name', tankName);
            formData.append('status', isEnabled);

            fetch('admin.php?ajax=1', {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const statusTd = document.getElementById('status-' + btoa(tankName).replace(/=/g, ''));
                    if (statusTd) {
                        if (isEnabled) {
                            statusTd.innerHTML = '<span class="status-active">Доступний</span>';
                        } else {
                            statusTd.innerHTML = '<span class="status-disabled">Відключений</span>';
                        }
                    }
                } else {
                    alert('Помилка оновлення статусу: ' + data.error);
                    checkbox.checked = !checkbox.checked;
                }
            })
            .catch(err => {
                alert('Помилка зв\'язку з сервером');
                checkbox.checked = !checkbox.checked;
            });
        }
    </script>
</head>
<body>


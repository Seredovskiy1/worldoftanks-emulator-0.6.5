<?php
require_once 'db.php';

if (isset($_SESSION['user_id'])) {
    header('Location: profile.php');
    exit;
}

$error = '';

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $username = trim($_POST['username'] ?? '');
    $password = $_POST['password'] ?? '';

    if (empty($username) || empty($password)) {
        $error = 'Будь ласка, заповніть усі поля.';
    } else {
        try {
            $stmt = $pdo->prepare("SELECT id, username, password_hash, is_admin FROM accounts WHERE username = ? OR normalized_name = ?");
            $stmt->execute([$username, $username]);
            $user = $stmt->fetch();

            if ($user && hash('sha256', $password) === $user['password_hash']) {
                $_SESSION['user_id'] = $user['id'];
                $_SESSION['username'] = $user['username'];
                $_SESSION['is_admin'] = (intval($user['is_admin']) === 1);

                $now = date('Y-m-d H:i:s');
                $update_stmt = $pdo->prepare("UPDATE accounts SET last_login = ? WHERE id = ?");
                $update_stmt->execute([$now, $user['id']]);

                header('Location: profile.php');
                exit;
            } else {
                $error = 'Невірне ім\'я користувача або пароль.';
            }
        } catch (Exception $e) {
            $error = 'Помилка бази даних: ' . $e->getMessage();
        }
    }
}
?>

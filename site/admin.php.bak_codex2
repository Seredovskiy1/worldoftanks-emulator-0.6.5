<div class="main-layout admin-shell">
    <div class="admin-grid">
        <div class="admin-stack">
            <div class="card">
                <div class="card-header">
                    <div class="card-title">Гравці</div>
                </div>
                <div class="card-body">
                    <form action="admin.php" method="GET" class="search-box">
                        <input type="text" name="account_search" class="form-control search-input" placeholder="ID або нік" value="<?php echo h($account_search); ?>">
                        <button type="submit" class="btn btn-secondary">Знайти</button>
                    </form>
                    <div class="account-list">
                        <?php foreach ($accounts as $account): ?>
                            <?php
                            $query = $_GET;
                            $query['account_id'] = intval($account['id']);
                            $query['page'] = 1;
                            $url = 'admin.php?' . http_build_query($query);
                            ?>
                            <a class="account-link <?php echo intval($account['id']) === $selected_account_id ? 'active' : ''; ?>" href="<?php echo h($url); ?>">
                                #<?php echo intval($account['id']); ?> <?php echo h($account['username']); ?>
                                <span class="account-meta"><?php echo intval($account['is_admin']) === 1 ? 'адмін' : 'гравець'; ?> · <?php echo h($account['last_login'] ?? ''); ?></span>
                            </a>
                        <?php endforeach; ?>
                        <?php if (empty($accounts)): ?>
                            <span class="muted">Гравців не знайдено.</span>
                        <?php endif; ?>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-title">Акаунт</div>
                </div>
                <div class="card-body">
                    <?php if ($selected_account): ?>
                        <form onsubmit="return saveAccount(this);" class="admin-form-grid">
                            <input type="hidden" name="account_id" value="<?php echo intval($selected_account['id']); ?>">
                            <div class="form-group">
                                <label>Кредити</label>
                                <input type="number" name="credits" class="form-control" min="0" value="<?php echo intval($selected_account['credits']); ?>">
                            </div>
                            <div class="form-group">
                                <label>Золото</label>
                                <input type="number" name="gold" class="form-control" min="0" value="<?php echo intval($selected_account['gold']); ?>">
                            </div>
                            <div class="form-group">
                                <label>Вільний досвід</label>
                                <input type="number" name="free_xp" class="form-control" min="0" value="<?php echo intval($selected_account['free_xp']); ?>">
                            </div>
                            <div class="form-group">
                                <label>Слоти</label>
                                <input type="number" name="slots" class="form-control" min="1" value="<?php echo intval($selected_account['slots']); ?>">
                            </div>
                            <div class="form-group">
                                <label>Казарма</label>
                                <input type="number" name="berths" class="form-control" min="0" value="<?php echo intval($selected_account['berths']); ?>">
                            </div>
                            <div class="form-group">
                                <label>Права</label>
                                <label style="display:flex; align-items:center; gap:8px; color:#cccccc; text-transform:none; letter-spacing:0;">
                                    <input type="checkbox" name="is_admin" <?php echo intval($selected_account['is_admin']) === 1 ? 'checked' : ''; ?>>
                                    Адміністратор
                                </label>
                            </div>
                            <div class="full table-actions">
                                <button type="submit" class="btn btn-primary">Зберегти</button>
                                <button type="button" class="btn btn-secondary" onclick="resetOverrides()">Скинути override-и</button>
                            </div>
                        </form>
                    <?php else: ?>
                        <span class="muted">Вибери гравця для персонального керування.</span>
                    <?php endif; ?>
                </div>
            </div>
        </div>

        <div class="admin-stack">
            <div class="metric-grid">
                <div class="metric">
                    <div class="metric-value"><?php echo $total_accounts; ?></div>
                    <div class="metric-label">акаунтів</div>
                </div>
                <div class="metric">
                    <div class="metric-value"><?php echo count($vehicles); ?></div>
                    <div class="metric-label">танків у JSON</div>
                </div>
                <div class="metric">
                    <div class="metric-value"><?php echo count($disabled_tanks); ?></div>
                    <div class="metric-label">глобально вимкнено</div>
                </div>
                <div class="metric">
                    <div class="metric-value"><?php echo $override_count; ?></div>
                    <div class="metric-label">персональних правил</div>
                </div>
            </div>

            <div id="adminNotice" class="notice-line alert"></div>

            <div class="card">
                <div class="card-header">
                    <div class="card-title">Доступ до техніки</div>
                    <div class="muted">Подій: <?php echo $event_count; ?></div>
                </div>
                <div class="card-body">
                    <form action="admin.php" method="GET" class="admin-toolbar">
                        <input type="hidden" name="account_id" value="<?php echo intval($selected_account_id); ?>">
                        <input type="text" name="search" class="form-control search-input" placeholder="Пошук танка" value="<?php echo h($search); ?>">
                        <select name="nation" class="form-control">
                            <option value="">Всі нації</option>
                            <?php foreach (['ussr', 'germany', 'usa', 'france', 'china', 'uk', 'japan'] as $nation): ?>
                                <option value="<?php echo h($nation); ?>" <?php echo $filter_nation === $nation ? 'selected' : ''; ?>><?php echo h(nation_label($nation)); ?></option>
                            <?php endforeach; ?>
                        </select>
                        <select name="class" class="form-control">
                            <option value="">Всі класи</option>
                            <?php foreach (['lightTank', 'mediumTank', 'heavyTank', 'AT-SPG', 'SPG'] as $class): ?>
                                <option value="<?php echo h($class); ?>" <?php echo $filter_class === $class ? 'selected' : ''; ?>><?php echo h(class_label($class)); ?></option>
                            <?php endforeach; ?>
                        </select>
                        <select name="tier" class="form-control">
                            <option value="">Всі рівні</option>
                            <?php for ($tier = 1; $tier <= 10; $tier++): ?>
                                <option value="<?php echo $tier; ?>" <?php echo $filter_tier === (string)$tier ? 'selected' : ''; ?>><?php echo $tier; ?></option>
                            <?php endfor; ?>
                        </select>
                        <select name="status" class="form-control">
                            <option value="">Всі статуси</option>
                            <option value="global_enabled" <?php echo $filter_status === 'global_enabled' ? 'selected' : ''; ?>>Глобально увімкнені</option>
                            <option value="global_disabled" <?php echo $filter_status === 'global_disabled' ? 'selected' : ''; ?>>Глобально вимкнені</option>
                            <option value="effective_enabled" <?php echo $filter_status === 'effective_enabled' ? 'selected' : ''; ?>>Доступні гравцю</option>
                            <option value="effective_disabled" <?php echo $filter_status === 'effective_disabled' ? 'selected' : ''; ?>>Закриті гравцю</option>
                            <option value="overridden" <?php echo $filter_status === 'overridden' ? 'selected' : ''; ?>>Є override</option>
                        </select>
                        <button type="submit" class="btn btn-primary">Фільтр</button>
                        <a href="admin.php?account_id=<?php echo intval($selected_account_id); ?>" class="btn btn-secondary">Скинути</a>
                        <button type="button" class="btn btn-secondary" onclick="enableAllGlobal()">Увімкнути все</button>
                    </form>

                    <div class="tanks-table-container">
                        <table class="tanks-table">
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Танк</th>
                                    <th>Нація</th>
                                    <th>Клас</th>
                                    <th>Рівень</th>
                                    <th>Для всіх</th>
                                    <th>Для гравця</th>
                                    <th>Ефективно</th>
                                </tr>
                            </thead>
                            <tbody>
                                <?php foreach ($paginated_vehicles as $vehicle): ?>
                                    <?php
                                    $name = $vehicle['name'] ?? '';
                                    $global_enabled = $vehicle['global_enabled'];
                                    $effective_enabled = $vehicle['effective_enabled'];
                                    $override_mode = $vehicle['override_mode'];
                                    ?>
                                    <tr data-vehicle-name="<?php echo h($name); ?>" data-global-enabled="<?php echo $global_enabled ? '1' : '0'; ?>" data-override-mode="<?php echo h($override_mode); ?>">
                                        <td><?php echo intval($vehicle['inv_id']); ?></td>
                                        <td style="font-weight:700;color:#ffffff;"><?php echo h($name); ?></td>
                                        <td><span class="badge badge-<?php echo h($vehicle['nation'] ?? 'ussr'); ?>"><?php echo h(nation_label($vehicle['nation'] ?? '')); ?></span></td>
                                        <td><?php echo h(class_label($vehicle['vehicleClass'] ?? '')); ?></td>
                                        <td style="color:#e5a93b;font-weight:700;"><?php echo intval($vehicle['level_calculated']); ?></td>
                                        <td>
                                            <div class="table-actions">
                                                <span class="js-global-status"><?php echo $global_enabled ? '<span class="pill pill-on">Увімкнено</span>' : '<span class="pill pill-off">Вимкнено</span>'; ?></span>
                                                <label class="switch">
                                                    <input type="checkbox" <?php echo $global_enabled ? 'checked' : ''; ?> onchange="toggleGlobal(this)">
                                                    <span class="slider"></span>
                                                </label>
                                            </div>
                                        </td>
                                        <td>
                                            <?php if ($selected_account): ?>
                                                <select class="form-control mini-select" onchange="setPlayerMode(this)">
                                                    <option value="inherit" <?php echo $override_mode === 'inherit' ? 'selected' : ''; ?>>Як для всіх</option>
                                                    <option value="enabled" <?php echo $override_mode === 'enabled' ? 'selected' : ''; ?>>Увімкнути</option>
                                                    <option value="disabled" <?php echo $override_mode === 'disabled' ? 'selected' : ''; ?>>Вимкнути</option>
                                                </select>
                                            <?php else: ?>
                                                <span class="pill pill-neutral">без гравця</span>
                                            <?php endif; ?>
                                        </td>
                                        <td class="js-effective-status"><?php echo $effective_enabled ? '<span class="pill pill-on">Увімкнено</span>' : '<span class="pill pill-off">Вимкнено</span>'; ?></td>
                                    </tr>
                                <?php endforeach; ?>
                                <?php if (empty($paginated_vehicles)): ?>
                                    <tr>
                                        <td colspan="8" style="text-align:center;padding:28px;color:#8c8c8c;">Танків за цими фільтрами немає.</td>
                                    </tr>
                                <?php endif; ?>
                            </tbody>
                        </table>
                    </div>

                    <?php if ($total_pages > 1): ?>
                        <div class="pagination">
                            <?php
                            $start = max(1, $page - 4);
                            $end = min($total_pages, $page + 4);
                            for ($i = $start; $i <= $end; $i++):
                                $query_params = $_GET;
                                $query_params['page'] = $i;
                                $link = 'admin.php?' . http_build_query($query_params);
                            ?>
                                <a href="<?php echo h($link); ?>" class="pagination-item <?php echo $page === $i ? 'active' : ''; ?>"><?php echo $i; ?></a>
                            <?php endfor; ?>
                        </div>
                    <?php endif; ?>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="footer">
    <p>&copy; 2026 World of Tanks 0.6.5 Emulator. Адмін-панель керує тією самою базою, що й сервер.</p>
</div>


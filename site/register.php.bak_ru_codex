<?php
require_once 'db.php';

if (isset($_SESSION['user_id'])) {
    header('Location: profile.php');
    exit;
}

$error = '';
$success = '';

function normalize_login_name($username) {
    $username = trim($username);
    if (strpos($username, '@') !== false) {
        $parts = explode('@', $username);
        $username = $parts[0];
    }
    $filtered = '';
    for ($i = 0; $i < strlen($username); $i++) {
        $ch = $username[$i];
        if (ctype_alnum($ch) || $ch === '_' || $ch === '-' || $ch === '.') {
            $filtered .= $ch;
        }
    }
    $filtered = substr($filtered, 0, 24);
    return empty($filtered) ? 'player' : $filtered;
}

if ($_SERVER['REQUEST_METHOD'] === 'POST') {
    $username = trim($_POST['username'] ?? '');
    $password = $_POST['password'] ?? '';
    $password_confirm = $_POST['password_confirm'] ?? '';

    if (empty($username) || empty($password)) {
        $error = 'Будь ласка, заповніть усі поля.';
    } elseif (strlen($username) < 3 || strlen($username) > 24) {
        $error = 'Ім\'я користувача повинно бути від 3 до 24 символів.';
    } elseif (strlen($password) < 6) {
        $error = 'Пароль повинен бути не менше 6 символів.';
    } elseif ($password !== $password_confirm) {
        $error = 'Паролі не співпадають.';
    } else {
        $normalized = normalize_login_name($username);

        try {
            $stmt = $pdo->prepare("SELECT COUNT(*) FROM accounts WHERE normalized_name = ? OR username = ?");
            $stmt->execute([$normalized, $username]);
            if ($stmt->fetchColumn() > 0) {
                $error = 'Цей акаунт вже існує.';
            } else {
                $password_hash = hash('sha256', $password);
                $now = date('Y-m-d H:i:s');

                $pdo->beginTransaction();

                $stmt = $pdo->prepare("INSERT INTO accounts (username, normalized_name, password_hash, created_at, last_login) VALUES (?, ?, ?, ?, ?)");
                $stmt->execute([$username, $normalized, $password_hash, $now, $now]);
                
                $new_id = $pdo->lastInsertId();

                $stmt = $pdo->prepare("INSERT INTO dossier (account_id) VALUES (?)");
                $stmt->execute([$new_id]);

                $pdo->commit();

                $success = 'Реєстрація успішна! Тепер ви можете увійти.';
            }
        } catch (Exception $e) {
            if ($pdo->inTransaction()) {
                $pdo->rollBack();
            }
            $error = 'Помилка бази даних: ' . $e->getMessage();
        }
    }
}
?>

                                                    <option value="inherit" <?php echo $override_mode === 'inherit' ? 'selected' : ''; ?>>Як глобально</option>
                                                    <option value="enabled" <?php echo $override_mode === 'enabled' ? 'selected' : ''; ?>>Увімкнути</option>
                                                    <option value="disabled" <?php echo $override_mode === 'disabled' ? 'selected' : ''; ?>>Вимкнути</option>
                                                </select>
                                            <?php else: ?>
                                                <span class="pill pill-neutral">без гравця</span>
                                            <?php endif; ?>
                                        </td>
                                        <td class="js-effective-status"><?php echo $effective_enabled ? '<span class="pill pill-on">Увімкнено</span>' : '<span class="pill pill-off">Вимкнено</span>'; ?></td>
                                    </tr>
                                <?php endforeach; ?>
                                <?php if (empty($paginated_vehicles)): ?>
                                    <tr>
                                        <td colspan="8" class="admin-empty">Танків за цими фільтрами немає.</td>
